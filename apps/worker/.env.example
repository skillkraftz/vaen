# Worker environment — copy to apps/worker/.env and fill in values.
#
# These are loaded automatically by run-job.ts via dotenv.
# The worker uses the service_role key to bypass RLS for DB writes.

# Supabase — required
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Discord — optional (worker sends notifications for generate/review events)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Portal URL — used in Discord notification links
NEXT_PUBLIC_PORTAL_URL=http://localhost:3100
