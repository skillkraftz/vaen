# Supabase — required
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key — used by the worker for DB access (bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Discord — optional (notifications skipped if not set)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Portal URL — used in Discord notification links
NEXT_PUBLIC_PORTAL_URL=http://localhost:3100
